<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HB3D Calculateur Impression 3D</title>
<!-- HB3D Calculateur v1.1 - Force redeploy -->
  <style>
    /* CSS HB3D = ta maquette vert/orange */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Arial, sans-serif; background: #f5f5f5; padding: 20px; }
    
    .hb3d-container {
      max-width: 1200px; margin: 0 auto; background: white; 
      border-radius: 20px; box-shadow: 0 20px 40px rgba(0,0,0,0.1);
      overflow: hidden;
    }
    
    .header {
      background: linear-gradient(135deg, #28a745, #20c997);
      color: white; padding: 30px; text-align: center;
    }
    
    .main-grid {
      display: grid; grid-template-columns: 1fr 350px; gap: 30px; padding: 30px;
    }
    
    .left-panel { 
      display: flex; flex-direction: column; gap: 20px;
    }
    
    .upload-zone {
      border: 3px dashed #28a745; border-radius: 15px; 
      padding: 40px; text-align: center; background: #f8fff8;
      cursor: pointer; transition: all 0.3s;
    }
    
    .upload-zone:hover { background: #e8f5e8; }
    
    .resultats {
      background: white; border-radius: 15px; padding: 25px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
    
    .prix-final {
      font-size: 36px; font-weight: bold; color: #28a745;
      text-align: center; margin: 20px 0;
    }
    
    .checkout-btn {
      background: linear-gradient(135deg, #ff6b35, #f7931e);
      color: white; border: none; padding: 20px 40px;
      font-size: 24px; font-weight: bold; border-radius: 15px;
      cursor: pointer; width: 100%; margin-top: 20px;
      transition: transform 0.3s;
    }
    
    .checkout-btn:hover { transform: scale(1.05); }
    
    .right-panel {
      background: #f8f9fa; border-radius: 15px; padding: 25px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
    
    @media (max-width: 768px) {
      .main-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="hb3d-container">
    <!-- HEADER HB3D -->
    <div class="header">
      <h1>🖨️ HB3D Calculateur Volume Impression 3D</h1>
      <p>Upload STL → Volume → Prix fixe 55.59€ TTC</p>
    </div>
    
    <!-- MAIN GRID -->
    <div class="main-grid">
      <!-- GAUCHE: Upload + Résultats -->
      <div class="left-panel">
        <!-- ZONE UPLOAD -->
        <div class="upload-zone" onclick="document.getElementById('fileInput').click()">
          <input type="file" id="fileInput" accept=".stl,.obj" style="display:none;" onchange="calculateVolume()">
          📁 Uploadez votre fichier 3D (STL/OBJ)
          <div style="margin-top:15px; font-size:20px;">ou glissez-déposez</div>
        </div>
        
        <!-- RÉSULTATS -->
        <div class="resultats">
          <h3>📊 Résultats analyse</h3>
          <div>Volume: <span id="volume">-- cm³</span></div>
          <div>Poids estimé: <span id="poids">-- g</span></div>
          <div class="prix-final" id="prix">55.59€ TTC</div>
        </div>
        
        <!-- CHECKOUT -->
        <button class="checkout-btn" onclick="checkout()">
          💳 Payer 55.59€ maintenant
        </button>
      </div>
      
      <!-- DROITE: Shopping + Détails -->
      <div class="right-panel">
        <h3>🛒 Panier HB3D</h3>
        <div>Quantité: <input type="number" value="1" min="1" id="qty"></div>
        <div>Prix unitaire: 55.59€</div>
        <div>Total: <strong id="total">55.59€</strong></div>
        
        <h4 style="margin-top:30px;">🎨 Options</h4>
        <select>
          <option>PLA Standard</option>
          <option>PETG+ Premium (+5€)</option>
          <option>ASA Extérieur (+10€)</option>
        </select>
        
        <h4>Détails</h4>
        <input placeholder="Nom" style="width:100%;padding:10px;margin:5px 0;">
        <input placeholder="Email" style="width:100%;padding:10px;margin:5px 0;">
        <textarea placeholder="Instructions spéciales" style="width:100%;padding:10px;height:80px;"></textarea>
      </div>
    </div>
  </div>

  <script>
    // Calculateur volume (simulé)
    function calculateVolume() {
      const file = document.getElementById('fileInput').files[0];
      if (file) {
        document.getElementById('volume').textContent = '125';
        document.getElementById('poids').textContent = '85';
        document.querySelector('.upload-zone').innerHTML = `
          ✅ <strong>${file.name}</strong> analysé<br>
          📁 Volume: 125 cm³ | Poids: 85g
        `;
      }
    }
    
    // Checkout 55€
    function checkout() {
      alert('🚀 Checkout Stripe 55.59€ → EmailJS HB3D !');
      // Stripe + EmailJS ici
    }
    
    // Update total qty
    document.getElementById('qty').addEventListener('input', function() {
      const qty = this.value;
      const total = (55.59 * qty).toFixed(2);
      document.getElementById('total').textContent = total + '€';
      document.getElementById('prix').textContent = total + '€ TTC';
    });
  </script>
</body>
</html>
